{
  "name": "scrape-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "scrape-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "scrape-agent": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "worker": "tsx src/cli.ts run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@narduk-enterprises/scrape-contract": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
